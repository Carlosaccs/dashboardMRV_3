<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard MRV SP</title>
    <style>
        /* CSS RESET E ESTRUTURA BASE */
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body, html { height: 100vh; overflow: hidden; background: #fff; }
        
        header { 
            background: rgb(6, 94, 3); height: 50px; display: flex; 
            align-items: center; justify-content: center; color: white; 
            z-index: 100; position: relative;
        }
        
        .main-wrapper { display: flex; height: calc(100% - 50px); width: 100%; background: #fff; }

        /* COLUNAS LATERAIS */
        .col-lateral-esq { width: 25%; background: #fff; overflow-y: auto; padding: 10px; border-right: 1px solid #ddd; }
        .col-lateral-dir { width: 25%; background: #fff; padding: 15px; overflow-y: auto; border-left: 1px solid #ddd; }

        /* BOTÕES RESIDENCIAIS */
        .btRes { 
            width: 100%; padding: 8px 12px; margin-bottom: 4px; background: transparent; 
            border: none; border-left: 5px solid rgb(6, 94, 3); 
            text-align: left; cursor: pointer; font-size: 0.72rem; 
            border-radius: 4px; display: flex; justify-content: space-between; align-items: center;
        }
        .btRes:hover { background: #f4f4f4; border-left-color: #ff8c00; }
        .btRes strong { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 65%; text-transform: uppercase; }
        .btRes.ativo { border-left-color: #ff8c00 !important; background: #fff5e6 !important; font-weight: bold; }
        
        .estoque-status { font-size: 0.65rem; font-weight: bold; color: #666; }
        .estoque-vendido { text-decoration: line-through; color: #999 !important; background: #f0f0f0; padding: 2px 4px; border-radius: 2px; }

        /* COLUNA CENTRAL E MAPA */
        .col-central { flex: 1; display: flex; flex-direction: column; background: #fff; position: relative; overflow: hidden; }
        .centro-topo { height: 40px; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.9rem; border-bottom: 1px solid #eee; background: #fdfdfd; }
        
        .container-mapas { flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative; }
        .caixa-troca { width: 100%; display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative; }
        
        /* Ajuste de Interatividade dos Mapas */
        .pos-cima { height: 78%; z-index: 5; }
        .pos-baixo { height: 22%; z-index: 10; cursor: pointer; }
        
        svg { width: 100%; height: 100%; display: block; padding: 10px; pointer-events: auto; }
        path { stroke: #fff; stroke-width: 0.5; fill: #838383; transition: fill 0.15s; pointer-events: auto; cursor: pointer; }
        
        .commrv, #grandesaopaulo { fill: rgb(6, 94, 3) !important; }
        path:hover { fill: #555; } /* Hover geral para feedback */
        .commrv:hover, #grandesaopaulo:hover { fill: #ff8c00 !important; }
        .path-ativo { fill: #ff8c00 !important; stroke: #000; stroke-width: 1.2px; }

        /* ESTILO DA FICHA DIREITA (PRINT) */
        .ficha-card { border-left: 5px solid #ff8c00; padding: 12px; border-radius: 4px; background: #fafafa; margin-top: 15px; }
        .ficha-header { font-size: 0.85rem; color: #065e03; font-weight: bold; text-transform: uppercase; margin-bottom: 10px; display: block; }
        
        .local-info { font-size: 0.75rem; color: #333; margin-bottom: 15px; display: flex; align-items: flex-start; gap: 6px; line-height: 1.4; }
        
        .ficha-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 15px; }
        .grid-item { font-size: 0.72rem; color: #333; }
        .grid-label { font-weight: bold; color: #666; margin-bottom: 2px; display: flex; align-items: center; gap: 4px; }

        .btn-acao { width: 100%; padding: 10px; margin-top: 8px; border: none; border-radius: 4px; color: white; font-weight: bold; cursor: pointer; font-size: 0.75rem; display: flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-book { background: #065e03; }
        .btn-video { background: #ff8c00; }
    </style>
</head>
<body>

    <header><h1>Residenciais MRV em São Paulo</h1></header>

    <div class="main-wrapper">
        <aside class="col-lateral-esq" id="menu-residenciais">Carregando...</aside>
        
        <main class="col-central">
            <div class="centro-topo" id="display-nome">Selecione uma região</div>
            <div class="container-mapas" id="container-mapas">
                <div id="caixa-a" class="caixa-troca pos-cima"></div>
                <div id="caixa-b" class="caixa-troca pos-baixo"></div>
            </div>
        </main>

        <aside class="col-lateral-dir" id="detalhes-residencial">
            <div style="text-align: center; color: #999; margin-top: 50px;">Selecione um residencial.</div>
        </aside>
    </div>

    <script src="mrv-data.js"></script>
    <script>
        let pathSelecionado = null;
        let botaoSelecionado = null;
        let regiaoAtual = "gsp"; 
        let DADOS_PLANILHA = [];

        async function carregarPlanilha() {
            try {
                const url = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQzECvkefpM6aWy0IacqqI6l84_ti6zS1lSjcrgL0J4OcrtWZLb63sh7U1ZTQ4nsqDMeTU5ykl8xtDe/pub?output=csv";
                const response = await fetch(url);
                const texto = await response.text();
                const linhas = texto.split(/\r?\n/).filter(l => l.trim() !== "");
                
                DADOS_PLANILHA = linhas.slice(1).map(linha => {
                    // Parser que ignora vírgulas dentro de aspas (essencial para endereços e decimais)
                    const col = linha.split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/).map(c => c.trim().replace(/^"|"$/g, ''));
                    
                    // FILTRO DE INTRUSOS: Apenas linhas que pareçam nomes de residenciais reais
                    const nomeValidado = col[2] || "";
                    if (!nomeValidado.toLowerCase().startsWith("res") && !nomeValidado.toLowerCase().startsWith("vista")) return null;

                    return {
                        id_path: col[0], 
                        regiao: col[1] ? col[1].toLowerCase() : "", 
                        nome: nomeValidado,
                        estoque: parseInt(col[3]) || 0,
                        endereco_comp: `${col[4]}, ${col[5]} - ${col[6]}`, // Rua, Bairro - Cidade
                        entrega: col[7], 
                        menor_preco: col[8], 
                        plantas: `de ${col[9]} até ${col[10]}`,
                        obra: col[11],
                        link_book: col[19] || "#"
                    };
                }).filter(item => item !== null);

                DADOS_PLANILHA.sort((a, b) => a.nome.localeCompare(b.nome));
                gerarListaGeral();
                desenharIniciais();
            } catch (e) { console.error("Erro ao carregar dados:", e); }
        }

        function formatarEstoque(qtd) {
            if (qtd === 0) return `<span class="estoque-status estoque-vendido">VENDIDO</span>`;
            if (qtd <= 5) return `<span class="estoque-status" style="color:red">restam ${qtd} un.</span>`;
            return `<span class="estoque-status">${qtd} unidades</span>`;
        }

        function gerarListaGeral() {
            const menu = document.getElementById('menu-residenciais');
            menu.innerHTML = "";
            DADOS_PLANILHA.forEach(item => {
                const btn = document.createElement('button');
                btn.className = 'btRes';
                btn.id = `btn-esq-${item.nome.replace(/[^a-zA-Z0-9]/g, '-')}`;
                btn.innerHTML = `<strong>${item.nome}</strong> ${formatarEstoque(item.estoque)}`;
                btn.onclick = () => selecionarResidencial(item, btn);
                menu.appendChild(btn);
            });
        }

        function selecionarResidencial(item, btn) {
            if (botaoSelecionado) botaoSelecionado.classList.remove('ativo');
            const btnEsq = btn || document.getElementById(`btn-esq-${item.nome.replace(/[^a-zA-Z0-9]/g, '-')}`);
            if (btnEsq) {
                btnEsq.classList.add('ativo');
                btnEsq.scrollIntoView({ behavior: 'auto', block: 'nearest' });
                botaoSelecionado = btnEsq;
            }
            
            // Se o residencial for de outra região, troca o mapa mas mantém a ficha
            if (item.regiao && item.regiao !== regiaoAtual) solicitarTroca(true);
            
            const el = document.getElementById(item.id_path);
            if(el) destacarNoMapa(el);
            exibirPainelDireito(item, el ? el.getAttribute('data-name') : item.cidade);
        }

        function exibirPainelDireito(item, nomeCidade) {
            const painel = document.getElementById('detalhes-residencial');
            let html = `<div style="font-size:0.75rem; font-weight:bold; color:#065e03; margin-bottom:12px;">MRV em ${nomeCidade || 'Região'}:</div>`;
            
            const vizinhos = DADOS_PLANILHA.filter(d => d.id_path === item.id_path && d.nome !== item.nome);
            vizinhos.forEach(v => {
                html += `<button class="btRes" onclick='selecionarResidencial(${JSON.stringify(v).replace(/'/g, "&apos;")}, null)'>
                            <strong>${v.nome}</strong> ${formatarEstoque(v.estoque)}
                         </button>`;
            });

            html += `
                <div class="ficha-card">
                    <span class="ficha-header">${item.nome} - ${formatarEstoque(item.estoque)}</span>
                    
                    <div class="local-info">
                        <span>📍</span> <span>${item.endereco_comp}</span>
                    </div>

                    <div class="ficha-grid">
                        <div class="grid-item">
                            <div class="grid-label">💰 Menor preço:</div>
                            ${item.menor_preco || 'Sob consulta'}
                        </div>
                        <div class="grid-item">
                            <div class="grid-label">🔑 Entrega:</div>
                            ${item.entrega}
                        </div>
                        <div class="grid-item">
                            <div class="grid-label">📐 Plantas:</div>
                            ${item.plantas}
                        </div>
                        <div class="grid-item">
                            <div class="grid-label">🏗️ Obra:</div>
                            ${item.obra}${item.obra.toString().includes('%') ? '' : '%'}
                        </div>
                    </div>

                    <button class="btn-acao btn-book" onclick="window.open('${item.link_book}', '_blank')">📄 Abrir Book</button>
                    <button class="btn-acao btn-video" onclick="alert('Link do vídeo copiado!')">🎥 Copiar Vídeo</button>
                </div>`;
            painel.innerHTML = html;
        }

        function destacarNoMapa(el) {
            if (pathSelecionado) pathSelecionado.classList.remove('path-ativo');
            el.classList.add('path-ativo');
            pathSelecionado = el;
            document.getElementById('display-nome').innerText = el.getAttribute('data-name');
        }

        function solicitarTroca(manterFicha = false) {
            regiaoAtual = (regiaoAtual === "gsp") ? "esp" : "gsp";
            const cA = document.getElementById('caixa-a'), cB = document.getElementById('caixa-b');
            const container = document.getElementById('container-mapas');
            
            if (cA.classList.contains('pos-cima')) {
                cA.className = 'caixa-troca pos-baixo';
                cB.className = 'caixa-troca pos-cima';
                container.appendChild(cA); 
            } else {
                cB.className = 'caixa-troca pos-baixo';
                cA.className = 'caixa-troca pos-cima';
                container.appendChild(cB); 
            }
            
            if (pathSelecionado) pathSelecionado.classList.remove('path-ativo');
            pathSelecionado = null;

            if (!manterFicha) {
                document.getElementById('detalhes-residencial').innerHTML = '<div style="text-align: center; color: #999; margin-top: 50px;">Selecione um residencial.</div>';
                document.getElementById('display-nome').innerText = (regiaoAtual === "gsp" ? "Grande São Paulo" : "Interior / Litoral");
            }
        }

        function desenhar(idContainer, dados) {
            const container = document.getElementById(idContainer);
            if (!container || !dados) return;
            const paths = dados.paths.map(p => {
                const temMRV = DADOS_PLANILHA.some(d => d.id_path === p.id);
                const classeBase = p.class || "";
                return `<path id="${p.id}" data-name="${p.name || p.id}" d="${p.d}" class="${classeBase} ${(temMRV || p.id === 'grandesaopaulo') ? 'commrv' : ''}"></path>`;
            }).join('');
            container.innerHTML = `<svg viewBox="${dados.viewBox}" preserveAspectRatio="xMidYMid meet"><g transform="${dados.transform || ''}">${paths}</g></svg>`;
        }

        function desenharIniciais() {
            if (typeof MAPA_GSP !== 'undefined') desenhar('caixa-a', MAPA_GSP);
            if (typeof MAPA_INTERIOR !== 'undefined') desenhar('caixa-b', MAPA_INTERIOR);
        }

        // EVENTOS DE MOUSE - CORRIGIDOS PARA HOVER FUNCIONAR
        document.getElementById('container-mapas').addEventListener('mouseover', (e) => {
            const p = e.target.closest('.pos-cima path');
            if (p) {
                document.getElementById('display-nome').innerText = p.getAttribute('data-name');
            }
        });

        document.getElementById('container-mapas').addEventListener('mouseleave', () => {
            if (pathSelecionado) {
                document.getElementById('display-nome').innerText = pathSelecionado.getAttribute('data-name');
            } else {
                document.getElementById('display-nome').innerText = (regiaoAtual === "gsp" ? "Grande São Paulo" : "Interior / Litoral");
            }
        });

        document.getElementById('container-mapas').addEventListener('click', (e) => {
            const caixaBaixo = e.target.closest('.pos-baixo');
            if (caixaBaixo) { solicitarTroca(false); return; }
            
            const p = e.target.closest('.pos-cima path');
            if (p) {
                if (p.id === "grandesaopaulo") { solicitarTroca(false); return; }
                const item = DADOS_PLANILHA.find(d => d.id_path === p.id);
                if(item) selecionarResidencial(item, null);
            }
        });

        window.onload = carregarPlanilha;
    </script>
</body>
</html>
