<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard MRV SP</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body, html { height: 100vh; overflow: hidden; background: #fff; }
        
        header { 
            background: rgb(6, 94, 3); height: 50px; display: flex; 
            align-items: center; justify-content: center; color: white; 
            z-index: 100; position: relative;
        }

        /* BOTÃO SOBRE */
        .btn-sobre {
            position: absolute; right: 20px; background: rgba(255,255,255,0.2);
            color: white; border: 1px solid white; padding: 5px 15px;
            border-radius: 20px; cursor: pointer; font-size: 0.75rem; transition: 0.3s;
        }
        .btn-sobre:hover { background: white; color: rgb(6, 94, 3); }
        
        .main-wrapper { display: flex; height: calc(100% - 50px); width: 100%; background: #fff; }

        .col-lateral-esq { width: 21%; background: #fff; overflow-y: auto; padding: 10px; border-right: 1px solid #ddd; }
        .col-lateral-dir { width: 32%; background: #fff; padding: 15px; overflow-y: auto; border-left: 1px solid #ddd; }
        .col-central { flex: 1; display: flex; flex-direction: column; background: #fff; position: relative; overflow: hidden; }

        .btRes { 
            width: 100%; padding: 8px 12px; margin-bottom: 4px; background: transparent; 
            border: none; border-left: 5px solid rgb(6, 94, 3); 
            text-align: left; cursor: pointer; font-size: 0.72rem; 
            border-radius: 4px; display: flex; justify-content: space-between; align-items: center;
        }
        .btRes:hover { background: #e0e0e0; border-left-color: #ff8c00; }
        .btRes strong { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 65%; text-transform: uppercase; }
        .btRes.ativo { border-left-color: #ff8c00 !important; background: #fff5e6 !important; font-weight: bold; }
        .estoque-status { font-size: 0.65rem; font-weight: bold; color: #666; }

        .centro-topo { height: 40px; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.9rem; border-bottom: 1px solid #eee; background: #fdfdfd; }
        .container-mapas { flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative; }
        .caixa-troca { width: 100%; display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative; }
        .pos-cima { height: 78%; z-index: 5; }
        .pos-baixo { height: 22%; z-index: 10; cursor: pointer; opacity: 0.8; }
        
        svg { width: 100%; height: 100%; display: block; padding: 10px; pointer-events: auto; }
        path { stroke: #fff; stroke-width: 0.5; fill: #838383; transition: fill 0.15s; pointer-events: auto; }
        path:hover { fill: #bbb; }
        .commrv, #grandesaopaulo { fill: rgb(6, 94, 3) !important; cursor: pointer; }
        .commrv:hover, #grandesaopaulo:hover { fill: #ff8c00 !important; }
        .path-ativo { fill: #ff8c00 !important; stroke: #000; stroke-width: 1.2px; }

        .ficha-card { border-left: 5px solid #ff8c00; padding: 12px; border-radius: 4px; background: #fafafa; margin-top: 15px; }
        .ficha-header { font-size: 0.9rem; color: #065e03; font-weight: bold; text-transform: uppercase; margin-bottom: 8px; display: block; }
        .local-info { font-size: 0.75rem; color: #333; margin-bottom: 12px; display: flex; align-items: flex-start; gap: 6px; line-height: 1.4; border-bottom: 1px solid #eee; padding-bottom: 8px; }
        
        .ficha-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 15px; }
        .grid-item { font-size: 0.72rem; color: #333; }
        .grid-label { font-weight: bold; color: #666; margin-bottom: 2px; font-size: 0.65rem; text-transform: uppercase; }

        .bloco-texto { margin-bottom: 10px; padding: 10px; border-radius: 6px; font-size: 0.75rem; line-height: 1.5; }
        .bloco-label { font-weight: bold; text-transform: uppercase; font-size: 0.6rem; display: block; margin-bottom: 5px; }
        .dica-box { background: #fff5e6; border: 1px solid #ffe0b3; color: #7a5a00; }
        .obs-box { background: #f1f3f5; border-left: 4px solid #adb5bd; color: #495057; }

        .secao-titulo { font-size: 0.65rem; font-weight: bold; color: #999; text-transform: uppercase; margin: 15px 0 8px 0; display: block; border-top: 1px solid #eee; padding-top: 10px; }
        .bloco-destaques { background: #fff; padding: 8px; border-radius: 6px; border: 1px solid #eee; margin-bottom: 15px; }
        .destaque-item { font-size: 0.7rem; color: #555; display: flex; align-items: flex-start; gap: 8px; margin-bottom: 6px; line-height: 1.2; }
        .destaque-icon { font-size: 0.85rem; min-width: 18px; text-align: center; }
        .destaque-texto strong { color: #065e03; font-size: 0.6rem; text-transform: uppercase; display: block; }

        .linha-link { display: flex; align-items: center; justify-content: space-between; padding: 8px; background: #fff; border: 1px solid #eee; border-radius: 6px; margin-bottom: 6px; gap: 8px; }
        .link-nome { font-size: 0.72rem; font-weight: bold; color: #444; display: flex; align-items: center; gap: 6px; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .btn-mini { padding: 6px 10px; border: none; border-radius: 4px; color: white; font-size: 0.62rem; font-weight: bold; cursor: pointer; }
        .btn-abrir { background: #065e03; }
        .btn-copiar { background: #ff8c00; }

        /* MODAL SOBRE */
        .modal-overlay {
            position: fixed; top:0; left:0; width:100%; height:100%;
            background: rgba(0,0,0,0.6); display: none; align-items: center;
            justify-content: center; z-index: 1000;
        }
        .modal-caixa {
            background: white; width: 90%; max-width: 500px; padding: 25px;
            border-radius: 12px; position: relative; text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .modal-fechar { position: absolute; top: 10px; right: 15px; cursor: pointer; font-size: 1.5rem; color: #999; }
        .modal-titulo { color: #065e03; font-weight: bold; margin-bottom: 15px; }
        .modal-texto { font-size: 0.85rem; color: #444; line-height: 1.6; margin-bottom: 20px; text-align: left; }
        .btn-whatsapp {
            display: inline-block; background: #25d366; color: white; padding: 12px 25px;
            text-decoration: none; border-radius: 30px; font-weight: bold; font-size: 0.9rem;
            transition: 0.3s;
        }
        .btn-whatsapp:hover { background: #128c7e; transform: scale(1.05); }

        #toast {
            visibility: hidden; min-width: 200px; background-color: #333; color: #fff;
            text-align: center; border-radius: 4px; padding: 10px; position: fixed;
            z-index: 1000; left: 50%; top: 30px; transform: translateX(-50%); font-size: 0.8rem;
        }
        #toast.show { visibility: visible; animation: fadein 0.5s, fadeout 0.5s 1.5s; }
        @keyframes fadein { from {top: 0; opacity: 0;} to {top: 30px; opacity: 1;} }
        @keyframes fadeout { from {top: 30px; opacity: 1;} to {top: 0; opacity: 0;} }
    </style>
</head>
<body>

    <header>
        <h1>Residenciais MRV em São Paulo</h1>
        <button class="btn-sobre" onclick="toggleModal(true)">Sobre</button>
    </header>

    <div class="main-wrapper">
        <aside class="col-lateral-esq" id="menu-residenciais">Carregando...</aside>
        
        <main class="col-central">
            <div class="centro-topo" id="display-nome">Selecione uma região</div>
            <div class="container-mapas" id="container-mapas">
                <div id="caixa-a" class="caixa-troca pos-cima"></div>
                <div id="caixa-b" class="caixa-troca pos-baixo"></div>
            </div>
        </main>

        <aside class="col-lateral-dir" id="detalhes-residencial">
            <div style="text-align: center; color: #999; margin-top: 50px;">Selecione um residencial ou clique em uma região verde do mapa.</div>
        </aside>
    </div>

    <div class="modal-overlay" id="modal-sobre" onclick="toggleModal(false)">
        <div class="modal-caixa" onclick="event.stopPropagation()">
            <span class="modal-fechar" onclick="toggleModal(false)">&times;</span>
            <div class="modal-titulo">Sobre o Projeto</div>
            <div class="modal-texto">
                Este dashboard foi desenvolvido para agilizar o acesso a informações básicas sobre os residenciais MRV de SP, auxiliando no atendimento rápido aos nossos leads.<br><br>
                <strong>⚠️ Aviso Importante:</strong> As informações mostradas podem estar desatualizadas e até incorretas.<br><br>
                <strong>🤝 Colabore com o projeto!</strong><br>
                Sentiu falta de algum material? Se você tiver Books (PDF), Vídeos ou fotos de decorados que ainda não estão aqui, se encontrou alguma informação incorretase ou se pode colaborar com dicas melhores ou observações sobre um residencial, por favor, envie para que possamos manter a ferramenta completa para todos.
            </div>
            <a href="https://wa.me/551192617026?text=Olá Carlos, gostaria de colaborar com o Dashboard MRV!" target="_blank" class="btn-whatsapp">
                Carlos Custódio - (11) 9261-7026
            </a>
        </div>
    </div>

    <div id="toast">Link copiado!</div>

    <script src="mrv-data.js"></script>
    <script>
        let pathSelecionado = null;
        let botaoSelecionado = null;
        let regiaoAtual = "gsp"; 
        let DADOS_PLANILHA = [];

        function toggleModal(show) {
            document.getElementById('modal-sobre').style.display = show ? 'flex' : 'none';
        }

        async function carregarPlanilha() {
            try {
                const url = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQzECvkefpM6aWy0IacqqI6l84_ti6zS1lSjcrgL0J4OcrtWZLb63sh7U1ZTQ4nsqDMeTU5ykl8xtDe/pub?output=csv&cachebuster=" + new Date().getTime();
                const response = await fetch(url);
                const texto = await response.text();
                const linhas = texto.split(/\r?\n/).filter(l => l.trim() !== "");
                
                DADOS_PLANILHA = linhas.slice(1).map(linha => {
                    const col = linha.split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/).map(c => c.trim().replace(/^"|"$/g, ''));
                    if (!col[2]) return null;
                    return {
                        id_path: col[0].toLowerCase().trim(), regiao: col[1] ? col[1].toLowerCase() : "", 
                        nome: col[2], estoque: col[3] || "0", endereco_comp: `${col[4]}, ${col[5]} - ${col[6]}`,
                        entrega: col[7], menor_preco: col[8], plantas_txt: `de ${col[9]} até ${col[10]}`,
                        obra: col[11], localizacao: col[12], mobilidade: col[13], cultura_lazer: col[14],
                        comercio: col[15], saude_educacao: col[16], dica: col[17], obs: col[18],  
                        book_cli: col[19], book_corr: col[20], video1: col[21], video2: col[22],
                        aptVaranda: col[23], aptSemVaranda: col[24], aptGarden: col[25], outraPlanta: col[26],
                        linkLocalizacao: col[28], linkDescritivo: col[29], div1: col[30]
                    };
                }).filter(item => item !== null);

                DADOS_PLANILHA.sort((a, b) => a.nome.localeCompare(b.nome));
                gerarListaGeral();
                desenharIniciais();
            } catch (e) { console.error("Erro nos dados:", e); }
        }

        function gerarLinkDireto(url) {
            if (!url || !url.includes("drive.google.com")) return url;
            const match = url.match(/\/file\/d\/(.+?)\//) || url.match(/id=(.+?)(&|$)/);
            if (match && match[1]) return `https://drive.google.com/file/d/${match[1].split('/')[0]}/preview`;
            return url;
        }

        function mostrarToast(texto) {
            const x = document.getElementById("toast");
            x.innerText = texto;
            x.className = "show";
            setTimeout(() => { x.className = x.className.replace("show", ""); }, 2000);
        }

        function copiarLink(url, nome) {
            if(!url || url.length < 5) return;
            const linkLimpo = gerarLinkDireto(url);
            navigator.clipboard.writeText(linkLimpo).then(() => mostrarToast(`${nome} copiado!`));
        }

        function renderLinkRow(label, link, ico) {
            if (!link || link.trim() === "" || link.length < 5) return "";
            return `
                <div class="linha-link">
                    <div class="link-nome"><span>${ico}</span> ${label}</div>
                    <div class="link-acoes">
                        <button class="btn-mini btn-abrir" onclick="window.open('${gerarLinkDireto(link)}', '_blank')">Abrir</button>
                        <button class="btn-mini btn-copiar" onclick="copiarLink('${link}', '${label}')">Copiar</button>
                    </div>
                </div>`;
        }

        function gerarListaGeral() {
            const menu = document.getElementById('menu-residenciais');
            menu.innerHTML = "";
            DADOS_PLANILHA.forEach(item => {
                const btn = document.createElement('button');
                btn.className = 'btRes';
                btn.id = `btn-esq-${item.nome.replace(/[^a-zA-Z0-9]/g, '-')}`;
                btn.innerHTML = `<strong>${item.nome}</strong> <span class="estoque-status">${item.estoque == '0' || item.estoque == 'VENDIDO' ? 'VENDIDO' : 'restam ' + item.estoque + ' un.'}</span>`;
                btn.onclick = () => selecionarResidencial(item, btn);
                menu.appendChild(btn);
            });
        }

        function selecionarResidencial(item, btn) {
            if (botaoSelecionado) botaoSelecionado.classList.remove('ativo');
            const btnEsq = btn || document.getElementById(`btn-esq-${item.nome.replace(/[^a-zA-Z0-9]/g, '-')}`);
            if (btnEsq) { btnEsq.classList.add('ativo'); btnEsq.scrollIntoView({ behavior: 'auto', block: 'nearest' }); botaoSelecionado = btnEsq; }
            if (item.regiao && item.regiao !== regiaoAtual) solicitarTroca(true);
            const el = document.getElementById(item.id_path);
            if(el) destacarNoMapa(el);
            exibirPainelDireito(item, el ? el.getAttribute('data-name') : "Região");
        }

        function exibirPainelDireito(item, nomeCidade) {
            const painel = document.getElementById('detalhes-residencial');
            let html = `<div style="font-size:0.75rem; font-weight:bold; color:#065e03; margin-bottom:12px;">MRV em ${nomeCidade}:</div>`;
            const vizinhos = DADOS_PLANILHA.filter(d => d.id_path === item.id_path && d.nome !== item.nome);
            vizinhos.forEach(v => {
                html += `<button class="btRes" onclick='selecionarResidencial(DADOS_PLANILHA.find(x=>x.nome=="${v.nome}"), null)'>
                            <strong>${v.nome}</strong> <span class="estoque-status">${v.estoque == '0' ? 'VENDIDO' : v.estoque + ' un.'}</span>
                         </button>`;
            });
            html += `
                <div class="ficha-card">
                    <span class="ficha-header">${item.nome}</span>
                    <div class="local-info"><span>📍</span> <span>${item.endereco_comp}</span></div>
                    <div class="ficha-grid">
                        <div class="grid-item"><div class="grid-label">💰 Preço:</div>${item.menor_preco || 'Sob consulta'}</div>
                        <div class="grid-item"><div class="grid-label">🔑 Entrega:</div>${item.entrega}</div>
                        <div class="grid-item"><div class="grid-label">📐 Plantas:</div>${item.plantas_txt}</div>
                        <div class="grid-item"><div class="grid-label">🏗️ Obra:</div>${item.obra}%</div>
                    </div>
                    ${item.dica ? `<div class="bloco-texto dica-box"><span class="bloco-label">💡 DICA DO ESPECIALISTA</span>${item.dica}</div>` : ''}
                    ${item.obs ? `<div class="bloco-texto obs-box"><span class="bloco-label">📝 Observações</span>${item.obs}</div>` : ''}
                    <span class="secao-titulo">Destaques da Região</span>
                    <div class="bloco-destaques">
                        ${item.localizacao ? `<div class="destaque-item"><span class="destaque-icon">📍</span><div class="destaque-texto"><strong>Localização</strong>${item.localizacao}</div></div>` : ''}
                        ${item.mobilidade ? `<div class="destaque-item"><span class="destaque-icon">🚆</span><div class="destaque-texto"><strong>Mobilidade</strong>${item.mobilidade}</div></div>` : ''}
                        ${item.cultura_lazer ? `<div class="destaque-item"><span class="destaque-icon">🌳</span><div class="destaque-texto"><strong>Lazer</strong>${item.cultura_lazer}</div></div>` : ''}
                        ${item.comercio ? `<div class="destaque-item"><span class="destaque-icon">🛒</span><div class="destaque-texto"><strong>Comércio</strong>${item.comercio}</div></div>` : ''}
                        ${item.saude_educacao ? `<div class="destaque-item"><span class="destaque-icon">🏥</span><div class="destaque-texto"><strong>Saúde</strong>${item.saude_educacao}</div></div>` : ''}
                    </div>
                    <span class="secao-titulo">Materiais de Apoio</span>
                    ${renderLinkRow("Book Cliente", item.book_cli, "📄")}
                    ${renderLinkRow("Book Corretor", item.book_corr, "💼")}
                    ${renderLinkRow("Vídeo 1", item.video1, "🎥")}
                    ${renderLinkRow("Vídeo 2", item.video2, "🎥")}
                    ${renderLinkRow("Localização", item.linkLocalizacao, "📍")}
                    ${renderLinkRow("Descritivo", item.linkDescritivo, "📑")}
                    <span class="secao-titulo">Plantas</span>
                    ${renderLinkRow("Apto c/ Varanda", item.aptVaranda, "🏢")}
                    ${renderLinkRow("Apto s/ Varanda", item.aptSemVaranda, "🏢")}
                    ${renderLinkRow("Apto Garden", item.aptGarden, "🏡")}
                    ${renderLinkRow("Outra Planta", item.outraPlanta, "📐")}
                    <span class="secao-titulo">Diversos</span>
                    ${renderLinkRow("Informações Adicionais", item.div1, "🔗")}
                </div>`;
            painel.innerHTML = html;
        }

        function destacarNoMapa(el) {
            if (pathSelecionado) pathSelecionado.classList.remove('path-ativo');
            el.classList.add('path-ativo');
            pathSelecionado = el;
            document.getElementById('display-nome').innerText = el.getAttribute('data-name');
        }

        function solicitarTroca(manterFicha = false) {
            regiaoAtual = (regiaoAtual === "gsp") ? "esp" : "gsp";
            if (!manterFicha && botaoSelecionado) {
                botaoSelecionado.classList.remove('ativo');
                botaoSelecionado = null;
            }
            const cA = document.getElementById('caixa-a'), cB = document.getElementById('caixa-b');
            const container = document.getElementById('container-mapas');
            if (cA.classList.contains('pos-cima')) {
                cA.className = 'caixa-troca pos-baixo'; cB.className = 'caixa-troca pos-cima';
                container.appendChild(cA); 
            } else {
                cB.className = 'caixa-troca pos-baixo'; cA.className = 'caixa-troca pos-cima';
                container.appendChild(cB); 
            }
            if (pathSelecionado) pathSelecionado.classList.remove('path-ativo');
            pathSelecionado = null;
            if (!manterFicha) {
                document.getElementById('detalhes-residencial').innerHTML = '<div style="text-align: center; color: #999; margin-top: 50px;">Selecione um residencial.</div>';
                document.getElementById('display-nome').innerText = (regiaoAtual === "gsp" ? "Grande São Paulo" : "Interior / Litoral");
            }
        }

        function desenhar(idContainer, dados) {
            const container = document.getElementById(idContainer);
            if (!container || !dados) return;
            const paths = dados.paths.map(p => {
                const temMRV = DADOS_PLANILHA.some(d => d.id_path === p.id.toLowerCase());
                return `<path id="${p.id}" data-name="${p.name || p.id}" d="${p.d}" class="${p.class || ''} ${(temMRV || p.id === 'grandesaopaulo') ? 'commrv' : ''}"></path>`;
            }).join('');
            container.innerHTML = `<svg viewBox="${dados.viewBox}" preserveAspectRatio="xMidYMid meet"><g transform="${dados.transform || ''}">${paths}</g></svg>`;
        }

        function desenharIniciais() {
            if (typeof MAPA_GSP !== 'undefined') desenhar('caixa-a', MAPA_GSP);
            if (typeof MAPA_INTERIOR !== 'undefined') desenhar('caixa-b', MAPA_INTERIOR);
        }

        document.getElementById('container-mapas').addEventListener('mouseover', (e) => {
            const p = e.target.closest('.pos-cima path');
            if (p) document.getElementById('display-nome').innerText = p.getAttribute('data-name');
        });
        document.getElementById('container-mapas').addEventListener('mouseleave', () => {
            document.getElementById('display-nome').innerText = pathSelecionado ? pathSelecionado.getAttribute('data-name') : (regiaoAtual === "gsp" ? "Grande São Paulo" : "Interior / Litoral");
        });

        document.getElementById('container-mapas').addEventListener('click', (e) => {
            const caixaBaixo = e.target.closest('.pos-baixo');
            if (caixaBaixo) { solicitarTroca(false); return; }
            const p = e.target.closest('.pos-cima path');
            if (p) {
                if (p.id === "grandesaopaulo") { solicitarTroca(false); return; }
                const item = DADOS_PLANILHA.find(d => d.id_path === p.id.toLowerCase());
                if(item && p.classList.contains('commrv')) selecionarResidencial(item, null);
            }
        });

        window.onload = carregarPlanilha;
    </script>
</body>
</html>
